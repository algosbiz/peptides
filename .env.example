# Copy to `.env` and adjust. `.env` is gitignored.

# Postgres (matches docker-compose.yml). App runs on host, DB in Docker.
DATABASE_URL=postgresql://datum:datum@localhost:5432/datum

# Session signing key — generate your own: `openssl rand -base64 32`
SESSION_SECRET=replace-me-with-a-long-random-string

# Seeded admin account (created/updated by `npm run db:seed`)
ADMIN_EMAIL=admin@datum.local
ADMIN_PASSWORD=changeme123
